{
  "version": "1",
  "rules": [
    {
      "id": "permit-generate",
      "effect": "permit",
      "principal": "*",
      "action": ["generate_text", "tool:echo"],
      "resource": "*"
    },
    {
      "id": "deny-writes-by-default",
      "effect": "forbid",
      "principal": "*",
      "action": ["tool:transfer", "tool:delete"],
      "resource": "*"
    }
  ]
}
